# Server Port
PORT=5000

# Database Configuration (Use individual params OR DATABASE_URL)
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=Merge
# DB_PORT=5432
# DB_SSL=true (Required for some cloud providers)

# Preferred for cloud providers like Render/Railway
DATABASE_URL=postgres://user:password@host:port/database

# Authentication
JWT_SECRET=your_super_secret_jwt_key

# AI Service URL (Point to your local machine IP if running AI locally)
AI_SERVICE_URL=http://your-local-ip:8001

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Deployment Safety
DISABLE_AI_SPAWN=true
FRONTEND_URL=https://your-frontend.vercel.app
